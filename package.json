{
  "name": "nexus-agent",
  "version": "1.0.0",
  "description": "Nexus AI Agent - The multi-MCP autonomous coding framework",
  "main": "dist/index.js",
  "bin": {
    "nexus": "dist/index.js"
  },
  "scripts": {
    "start": "node --loader ts-node/esm src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "tsc --outDir .tmp-build --declaration false --declarationMap false --sourceMap false && node .tmp-build/test/run-tests.js",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "skills",
    ".env.example",
    "README.md"
  ],
  "keywords": [
    "ai-agent",
    "coding-agent",
    "mcp",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "openai": "^6.35.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.2"
  }
}
