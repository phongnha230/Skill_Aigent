# LLM Provider (OpenAI, Ollama, etc.)
# ================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=http://localhost:11434/v1 # For Ollama

# ================================================
# MCP: PostgreSQL
# ================================================
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/mydb

# ================================================
# MCP: MySQL
# ================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=mydb

# ================================================
# MCP: MongoDB Atlas
# ================================================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mydb

# ================================================
# MCP: GitHub Actions
# ================================================
# Create at: github.com -> Settings -> Developer Settings -> Personal Access Tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# ================================================
# MCP: Docker
# (No extra keys needed — Docker Desktop must be running)
# ================================================
